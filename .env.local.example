# Resend — https://resend.com/api-keys
# Copy this file to .env.local and fill in your values.
# If RESEND_API_KEY is left blank, the waitlist API stubs a success
# response so you can develop the UI without a real backend.

RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Optional: get an email each time someone signs up.
# FROM_EMAIL must be a verified domain/sender in Resend.
FROM_EMAIL=
NOTIFY_EMAIL=
